{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Proxy",
  "version": "0.1.0",
  "identifier": "com.jamarq.proxy",
  "build": {
    "beforeDevCommand": "pnpm run renderer:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run renderer:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Proxy by JAMARQ",
        "width": 1280,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
