{
  "name": "@proxy/desktopapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec tauri dev",
    "renderer:dev": "vite --port 1420 --strictPort",
    "build": "pnpm exec tauri build --debug",
    "renderer:build": "vite build",
    "lint": "eslint src vite.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@proxy/config": "workspace:*",
    "@proxy/policy": "workspace:*",
    "@proxy/privacy": "workspace:*",
    "@proxy/profiles": "workspace:*",
    "@proxy/providers": "workspace:*",
    "@proxy/rewrite-engine": "workspace:*",
    "@proxy/ui": "workspace:*",
    "@proxy/validation": "workspace:*",
    "@tauri-apps/api": "2.10.1",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "vite": "8.0.0"
  }
}
